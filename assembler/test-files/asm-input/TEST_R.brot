; TEST.brot — Minimal BROT V0 smoke test (no labels)


ADDI r1, r0, 0x10:uint       ; r1 = scratch base
    ADDI r2, r0, 0x100:uint     ; r2 = data base
ADDI   r3, r0, 0x108:uint    ; r3 = data end
